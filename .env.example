LIDARR_BASE_URL=http://lidarr:8686/api/v1
LIDARR_HEADER_VALUE=<set-in-dokploy>
CACHE_DB=/data/media-maintenance-cache.json
REPORT_DIR=/data/reports

ALBUM_TARGET_METADATA_PROFILE_ID=3
ALBUM_APPLY=true
ALBUM_CONCURRENCY=16
ALBUM_MAX_ARTISTS_PER_RUN=1000
ALBUM_CACHE_DAYS=30
ALBUM_DURATION_TOLERANCE_MS=5000
ALBUM_PROCESS_ONLY_MONITORED_ARTISTS=true
ALBUM_PROCESS_ONLY_MONITORED_RELEASES=true
ALBUM_AUTO_UNMONITOR_DUPLICATES=true

DISK_DRY_RUN=true
DISK_MUSIC_ROOT=/media/music
DISK_LIDARR_MUSIC_ROOT=/music
DISK_QUARANTINE_ROOT=/media/.cleanup-quarantine
DISK_STALE_HOURS=72
DISK_MAX_FILES=100
DISK_MAX_BYTES=26843545600
DISK_SCAN_CONCURRENCY=16
DISK_MOVE_CONCURRENCY=2
